# Secrets for the Playwright e2e suite. Copy to .env.test (git-ignored).
# The service-role key is needed to provision + clean up the isolated test data;
# it bypasses RLS, so keep it out of the app and out of version control.

SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional — defaults are used if unset (the test user is auto-created):
# E2E_EMAIL=e2e@risuhome.test
# E2E_PASSWORD=e2e-Test-Pass-123!
